# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# Database Configuration
MONGO_URI=your_mongodb_connection_string

# Shopify App Credentials (from Shopify Partners Dashboard)
HOST=https://ecomlly-nu.vercel.app
PARTNER_CLIENT_ID=your_shopify_app_client_id
PARTNER_CLIENT_SECRET=your_shopify_app_client_secret
SHOPIFY_API_SECRET=your_shopify_api_secret

# Shopify Partner Management (Optional - used for webhook script automation)
PARTNER_API_ACCESS_TOKEN=your_partner_api_access_token
PARTNER_ORG_ID=your_partner_org_id

# Google Auth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
